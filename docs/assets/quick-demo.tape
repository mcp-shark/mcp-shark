# MCP Shark Quick Demo — Short GIF for README
# Record with: vhs docs/assets/quick-demo.tape

Output docs/assets/quick-demo.gif

Require npx

Set Shell "bash"
Set FontSize 18
Set Width 1000
Set Height 600
Set Padding 20
Set FontFamily "JetBrains Mono"
Set Theme "Catppuccin Mocha"
Set TypingSpeed 50ms
Set CursorBlink false

# Type the command
Type "npx @mcp-shark/mcp-shark"
Sleep 800ms
Enter

# Let scan output render
Sleep 4s

# Pause to read
Sleep 3s
