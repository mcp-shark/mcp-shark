# MCP Shark Quick Demo — Short GIF for README
# Record with: vhs docs/assets/quick-demo.tape

Output docs/assets/demo.gif

Set Shell "bash"
Set FontSize 16
Set Width 1100
Set Height 600
Set Padding 20
Set FontFamily "Menlo"
Set Theme "Catppuccin Mocha"
Set TypingSpeed 60ms
Set CursorBlink false

Sleep 500ms

Type "npx @mcp-shark/mcp-shark"
Sleep 500ms
Enter
Sleep 4s

Sleep 2s
