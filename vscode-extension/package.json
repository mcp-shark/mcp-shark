{
  "name": "mcp-shark-vscode",
  "displayName": "MCP Shark",
  "description": "Security scanner for AI agent tools — Shark Score in your status bar",
  "version": "0.1.0",
  "publisher": "mcp-shark",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mcp-shark.scan",
        "title": "MCP Shark: Run Security Scan"
      },
      {
        "command": "mcp-shark.fix",
        "title": "MCP Shark: Auto-Fix Issues"
      },
      {
        "command": "mcp-shark.list",
        "title": "MCP Shark: Show Server Inventory"
      }
    ],
    "configuration": {
      "title": "MCP Shark",
      "properties": {
        "mcp-shark.autoScan": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan on startup and config changes"
        },
        "mcp-shark.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show Shark Score in the status bar"
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint src",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
